# Voidforged MMO — Server & Client Configuration
# Copy to .env and fill in your values. Never commit .env files.

# ── Server Configuration ────────────────────────────────────────────────
SERVER_PORT=9876
SERVER_HOST=0.0.0.0
SERVER_MAX_PLAYERS=1000
SERVER_TICK_RATE=20

# ── PostgreSQL (primary game database) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/voidforged
# Connection pool settings:
PG_POOL_MIN=5
PG_POOL_MAX=25

# ── Redis (optional — sessions, leaderboards, world caches) ──────────────
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ── Authentication ──────────────────────────────────────────────────────
# JWT secret for session tokens. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-secure-random-string

# ── Client Configuration ────────────────────────────────────────────────
# Default server address shown in client's server browser
DEFAULT_SERVER_ADDRESS=127.0.0.1:9876

# ── Monitoring & Logging ────────────────────────────────────────────────
RUST_LOG=info
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ── Asset Storage (future) ──────────────────────────────────────────────
# S3-compatible storage for game assets (not yet implemented)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=voidforged-assets
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
